# .env.example — шаблон
# На сервере скопировать в .env и заполнить реальными значениями
# Файл .env НИКОГДА не пушить в git и не класть в образ!

BITBUCKET_URL=http://bitbucket.bank.ru
BITBUCKET_TOKEN=токен_от_ярослава

FENIX_URL=http://fenix.bank.ru/api/chat
FENIX_TOKEN=токен_от_ярослава
FENIX_MODEL=qwen

# Максимум строк диффа за один запрос к Фениксу
# Уменьши если выбиваешь лимит токенов
MAX_DIFF_LINES=300

# ── Параметры обращения к Фениксу (все опциональны — есть дефолты в коде) ──
# Можно вообще не задавать: бот возьмёт значения по умолчанию (указаны справа).
# Крутить эти переменные = менять поведение БЕЗ пересборки образа (только перезапуск).

# Лимит длины ответа модели. 4096 хватает на ревью (≤10 коротких замечаний).
# Меньше = быстрее и экономнее по лимиту ~700k ток/мин. Если в логах увидишь
# finish_reason=length (ответ обрезан) — подними.
FENIX_MAX_TOKENS=4096

# Таймаут запроса к Фениксу, секунды. На webhook НЕ влияет: бот отвечает Bitbucket
# 200 сразу, ревью идёт в фоне. Поднимай, если на пике не успевает сгенериться.
FENIX_TIMEOUT=90

# Сколько ревью обращаются к Фениксу одновременно. 1 = строго по очереди —
# защита от спайков по лимиту 700k ток/мин, когда PR прилетают пачкой.
FENIX_MAX_CONCURRENCY=1

# Повторы запроса при таймауте/429 (с backoff). 0 = выключить.
# Помогает в основном при 429 (лимит поминутный); от устойчивого пика не лечит.
FENIX_MAX_RETRIES=1
